#<_z_clearance> = 0.5
#<_rampang>     = 10
;#<_stepover>  = 0.1

;#<_overlap> = 0

; mode refernce
; +1: Conventional milling
; +2: Both-ways milling
; +4: Plunge entry
; +8: Outside


G20  ; G21 mm / G20 inch
G54  ; absolute coordinates

F5

#<_z_top> = 0.1
#<_z_bot> = -0.3
o<drill> call [5][-0.625]
o<drill> call [3][-0.625]
o<drill> call [1][-0.625]
o<drill> call [-1][-0.625]
o<drill> call [-3][-0.625]
o<drill> call [-5][-0.625]
o<drill> call [-7][-0.625]
o<drill> call [-9][-0.625]

M2 ; end program
