#<_z_clearance> = .5
#<_rampang>     = 10

; mode refernce
; +1: Conventional milling
; +2: Both-ways milling
; +4: Plunge entry
; +8: Outside

G20  ; G21 mm / G20 inch
G54  ; absolute coordinates

#<zt> = 0.02
#<zb> = -0.30

F10

#<_z_top> = #<zt>
#<_z_bot> = #<zb>
o<pocket_circ> call [0] [-.5-.394-1][-.5] [.33]

o<end_round> call [180] [-.5-.394-1][-.5] [.52] [#<zt>][#<zb>]


M2 ; end program
