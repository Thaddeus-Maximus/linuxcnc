G21  ; G21 mm / G20 inch
G54  ; absolute coordinates

#<_z_clearance> = 6
#<_rampang>     = 20

; mode refernce
; +1: Conventional milling
; +2: Both-ways milling
; +4: Plunge entry
; +8: Outside

F250  ; inch or mm/min (300 mm/min = about 1 ft/min)

o<drill_man> call [100][-80]
o<drill_man> call [100+24][-80+24]
o<drill_man> call [100+24][-80-24]
o<drill_man> call [100-24][-80-24]
o<drill_man> call [100-24][-80+24]


M2 ; end program
