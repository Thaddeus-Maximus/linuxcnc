; This is a great example of a hole pattern, manually drilled

F5
G90
;T1
M06

G54

o104 sub
	#<x> = [1.75 * COS[#1]]
	#<y> = [1.75 * SIN[#1]]

	G0 X#<x> Y#<y> ;Z1.0
	M102 ; disable Z-axis (M101 enables)
	M00  ; program pause
o104 endsub

o104 call [  0      ]
o104 call [ 60 + 6.5]
o104 call [120 - 6.5]
o104 call [180      ]
o104 call [240 + 6.5]
o104 call [300 - 6.5]


