#<_z_clearance> = 1.0
#<_rampang>     = 5

;#<_overlap> = 0

; +1: Conventional milling
; +2: Both-ways milling
; +4: Plunge entry
; +8: Outside


G10 L1 P1 Z0.0 R[3/25.4 /2] ; set tool
T1   ; set tool to T1
M06  ; manual toolchange
G54  ; absolute coordinates
F2   ; feedrate

