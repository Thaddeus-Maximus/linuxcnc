#<_z_clearance> = 1.0
#<_rampang>     = 5

;#<_overlap> = 0

; +1: Conventional milling
; +2: Both-ways milling
; +4: Plunge entry
; +8: Outside


G10 L1 P1 Z0.0 R0.125 ; set tool
T1   ; set tool to T1
M06  ; manual toolchange
G54  ; absolute coordinates
F10  ; 10 ft/min

#<_z_top> = 0.01
#<_z_bot> = -0.3
o<frame_circ> call [0] [2.5][-1.0] [1.381]

M2 ; end program
