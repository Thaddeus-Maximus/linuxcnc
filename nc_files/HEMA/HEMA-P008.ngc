#<_z_clearance> = 0.4
#<_rampang>     = 5

; mode reference
; +1: Conventional milling
; +2: Both-ways milling
; +4: Plunge entry
; +8: Outside


G20  ; G21 mm, G20 inches
G10 L1 P1 Z0.0 R[.1875/2] ; set tool
T1   ; set tool to T1
M06  ; manual toolchange
G54  ; absolute coordinates
;F10  ; mm/min (300 mm/min = about 1 ft/min)

